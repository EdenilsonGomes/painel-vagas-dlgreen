PORT=3000
NODE_ENV=production

# Use os mesmos dados da credencial PostgreSQL que já funciona no seu n8n.
PGHOST=nome-interno-do-servico-postgres
PGPORT=5432
PGDATABASE=recrutamento-db
PGUSER=admin
PGPASSWORD=sua-senha-do-postgres

# Normalmente false quando o painel e o PostgreSQL estão na mesma VPS/rede do EasyPanel.
DB_SSL=false

# Acesso temporário ao painel. Não é um sistema de vários usuários; é uma senha única.
ADMIN_USER=admin
ADMIN_PASSWORD=troque-por-uma-senha-forte-com-mais-de-10-caracteres

# Alternativa: em vez das variáveis PG..., você pode usar uma URL completa.
# DATABASE_URL=postgresql://admin:SENHA@HOST:5432/recrutamento-db
